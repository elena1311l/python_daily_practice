    max_sal=0
    for item in staff_list:
        if item["dept"]=="IT":
            current_bonus=item["salary"]/100*20
            
        elif item["dept"]=="Sales" and item["years"]>1:
            current_bonus=item["salary"]/100*15
            
        else:
            current_bonus=item["salary"]/100*10

           
        if item["years"]>5:
            current_bonus+=500

        item["bonuses"] = current_bonus
        item["salary"] +=current_bonus

        
        if item["salary"]>max_sal:
            max_sal=item["salary"]
            top_person=item["name"]
    
        
    return staff_list, top_person
