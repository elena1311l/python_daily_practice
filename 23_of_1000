def group_by_city(candidate_list):
    city_groups = {}
    for item in candidate_list:
        if item["city"] not in city_groups:
            city_groups[item["city"]]=[item["name"]]
        else:
            city_groups[item["city"]].append(item["name"])
    return city_groups
