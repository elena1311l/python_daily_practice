vacancy = "We need a Python developer with SQL and Git skills."
my_skills = ["python", "sql", "git", "docker", "java"]
def check_skills(vacancy_text, skills_list):
    new_list=[]
    lower_text=vacancy_text.lower()
    for item in skills_list:
        if item in lower_text:
            new_list.append(item)
    return new_list
