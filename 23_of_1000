]
def get_unique_skills(candidate_list):
    unique_skills = []
    for item in candidate_list:
        for skil in item["skills"]:
            if skil not in unique_skills:
                unique_skills.append(skil)
    return unique_skills
print(get_unique_skills(candidates))

def count_skills_frequency(candidate_list):
    skill_counts = {}
    for item in candidate_list:
        for skil in item["skills"]:
            if skil not in skill_counts:
                skill_counts[skil]=1
            else:
                skill_counts[skil]+=1
    return skill_counts
print(count_skills_frequency(candidates))

