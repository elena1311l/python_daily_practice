def find_top_skills(candidate_list):
    skills_scores={}
    for item in candidate_list:
        best_skill = []
        max_score = 0
        for skill, score in item["skills_scores"].items():
            if score>max_score:
                max_score=score
                best_skill=skill
        skills_scores[item["name"]]=f"{best_skill}({max_score})"
    return skills_scores

